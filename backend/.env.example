# AgentLens Backend Configuration
# Copy to .env and customize

# API key for authenticating SDK clients (required in production)
# If not set, the server runs without authentication (dev mode)
AGENTLENS_API_KEY=

# Comma-separated list of allowed CORS origins (required in production)
# If not set, all origins are allowed (dev mode)
# Example: CORS_ORIGINS=https://dashboard.example.com,http://localhost:3000
CORS_ORIGINS=

# Path to the SQLite database file (default: ./agentlens.db)
# Useful for Docker volumes or custom data directories
# DB_PATH=/data/agentlens.db

# Server port (default: 3000)
PORT=3000
