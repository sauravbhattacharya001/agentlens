# AgentLens Backend Configuration
# Copy to .env and customize

# API key for authenticating SDK clients (required in production)
# If not set, the server runs without authentication (dev mode)
AGENTLENS_API_KEY=

# Comma-separated list of allowed CORS origins (required in production)
# If not set, all origins are allowed (dev mode)
# Example: CORS_ORIGINS=https://dashboard.example.com,http://localhost:3000
CORS_ORIGINS=

# Path to the SQLite database file (default: ./agentlens.db)
# Useful for Docker volumes or custom data directories
# DB_PATH=/data/agentlens.db

# Server port (default: 3000)
PORT=3000

# Number of trusted reverse-proxy hops in front of the app. REQUIRED when
# running behind nginx, Traefik, Caddy, a cloud load balancer, Kubernetes
# ingress, ECS ALB, Cloud Run, Fly.io, etc. — otherwise express-rate-limit
# keys on the proxy IP and one noisy client can DoS the whole instance.
#
#   1                 → one proxy hop (e.g. nginx → app)
#   2                 → two hops      (e.g. CDN → nginx → app)
#   10.0.0.0/8        → trust a CIDR (comma-separated list also ok)
#   loopback          → Express named preset for 127.0.0.0/8 + ::1/128
#
# Leave UNSET when running directly without a reverse proxy. Do NOT set to
# "true" in production — that allows arbitrary X-Forwarded-For spoofing.
# See: https://expressjs.com/en/guide/behind-proxies.html
# AGENTLENS_TRUST_PROXY=1
